<title>Fondasyon Aksyon Ayisyen Kont Lamizè</title>

<style>
body{
font-family:Arial,sans-serif;
margin:0;
padding:0;
background:#f4f4f4;
}

header{
background:#003049;
color:white;
text-align:center;
padding:80px 20px;
}

header h1{
font-size:3em;
margin:0;
}

header p{
font-size:1.2em;
max-width:800px;
margin:auto;
}

.btn{
display:inline-block;
margin-top:20px;
padding:12px 30px;
background:#d62828;
color:white;
text-decoration:none;
border-radius:5px;
font-weight:bold;
}

section{
padding:50px 20px;
text-align:center;
background:white;
margin:20px;
